datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Tenant Layer (Multi-Tenancy)
model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logo      String?
  ownerId   String?
  owner     User?     @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  members    OrganizationMember[]
  invites    OrganizationInvite[]
  features   OrganizationFeature[]
  companies  Company[]
  contacts   Contact[]
  deals      Deal[]
  tasks      Task[]
  activities Activity[]
  auditLogs  AuditLog[]
  notifications Notification[]
  subscription Subscription?
  usageMetrics UsageMetric[]
  automationRules      AutomationRule[]
  automationExecutions AutomationExecution[]

  @@index([deletedAt])
}

// 2. User Accounts Mapped to Organization via memberships
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("USER") // USER, ADMIN
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Multi-Tenancy
  memberships        OrganizationMember[]
  ownedOrganizations Organization[]       @relation("OrganizationOwner")

  // Relations
  createdCompanies Company[]  @relation("CompanyCreator")
  ownedContacts    Contact[]  @relation("ContactOwner")
  createdContacts  Contact[]  @relation("ContactCreator")
  ownedDeals       Deal[]     @relation("DealOwner")
  createdDeals     Deal[]     @relation("DealCreator")
  assignedTasks    Task[]     @relation("TaskAssignee")
  createdTasks     Task[]     @relation("TaskCreator")
  activities       Activity[] @relation("Actor")
  sessions         Session[]
  auditLogs        AuditLog[]
  sentInvites      OrganizationInvite[] @relation("Inviter")
  notifications    Notification[]

  @@index([deletedAt])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id])
  joinedAt       DateTime     @default(now())
  invitedBy      String?

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([roleId])
}

// 3. Enterprise Company Accounts
model Company {
  id        String    @id @default(uuid())
  name      String
  domain    String?
  industry  String?
  employees Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Multi-Tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Auditing
  createdById String
  createdBy   User   @relation("CompanyCreator", fields: [createdById], references: [id], onDelete: Restrict)

  // Relations
  contacts Contact[]
  deals    Deal[]

  @@index([organizationId])
  @@index([createdById])
  @@index([deletedAt])
}

// 4. Client Contacts
model Contact {
  id        String    @id @default(uuid())
  name      String
  email     String
  phone     String?
  status    String    @default("LEAD") // LEAD, CONTACTED, CUSTOMER, CHURNED
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Company link (Nullable)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Multi-Tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Auditing & Ownership
  ownerId     String
  owner       User   @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdById String
  createdBy   User   @relation("ContactCreator", fields: [createdById], references: [id], onDelete: Restrict)

  // Relations
  deals      Deal[]

  @@index([organizationId])
  @@index([companyId])
  @@index([ownerId])
  @@index([createdById])
  @@index([status])
  @@index([deletedAt])
}

// 5. Pipeline Deals / Opportunities
model Deal {
  id        String    @id @default(uuid())
  title     String
  value     Float     @default(0.0)
  stage     String    @default("LEAD") // LEAD, CONTACTED, PROPOSAL, NEGOTIATION, WON, LOST
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Connections (Nullable)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Multi-Tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Auditing & Ownership
  ownerId     String
  owner       User   @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdById String
  createdBy   User   @relation("DealCreator", fields: [createdById], references: [id], onDelete: Restrict)

  // Relations
  tasks      Task[]

  @@index([organizationId])
  @@index([contactId])
  @@index([companyId])
  @@index([ownerId])
  @@index([createdById])
  @@index([stage])
  @@index([deletedAt])
}

// 6. Action Items & Tasks
model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("TODO") // BACKLOG, TODO, IN_PROGRESS, DONE, CANCELED
  priority    String    @default("MEDIUM") // HIGH, MEDIUM, LOW, NONE
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Pipeline Deal link (Nullable)
  dealId String?
  deal   Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  // Multi-Tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Auditing & Assignment
  assigneeId  String?
  assignee    User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([dealId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([status])
  @@index([priority])
  @@index([deletedAt])
}

// 7. Audit Logging history timeline (Multi-Tenancy Operational Stream)
model Activity {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorId        String?
  actor          User?        @relation("Actor", fields: [actorId], references: [id], onDelete: SetNull)
  entityType     String       // e.g. 'contact', 'company', 'deal', 'task', 'user'
  entityId       String
  action         String       // e.g. 'created', 'updated', etc.
  title          String
  description    String
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// 8. Session Management (SaaS Readiness Foundations)
model Session {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash            String   @unique
  ipAddress            String?
  userAgent            String?
  activeOrganizationId String?
  createdAt            DateTime @default(now())
  expiresAt            DateTime

  @@index([userId])
}

// 9. SaaS Audit Logging
model AuditLog {
  id             String   @id @default(uuid())
  action         String   // e.g. CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entityType     String   // e.g. COMPANY, CONTACT, DEAL, TASK, USER
  entityId       String?
  before         Json?
  after          Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  // Ownership and Multi-Tenancy
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

// 10. Organization Invitations
model OrganizationInvite {
  id             String       @id @default(uuid())
  email          String
  token          String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String
  invitedById    String
  invitedBy      User         @relation("Inviter", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([token])
  @@index([roleId])
  @@index([email])
}

// 11. Role-Based Access Control (RBAC)
model Role {
  id          String               @id
  name        String               @unique
  permissions RolePermission[]
  members     OrganizationMember[]
}

model Permission {
  id     String           @id
  action String           @unique
  roles  RolePermission[]
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// 12. Feature Flags
model Feature {
  id            String                @id
  name          String                @unique
  description   String?
  organizations OrganizationFeature[]
}

model OrganizationFeature {
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  featureId      String
  feature        Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)
  isEnabled      Boolean      @default(true)

  @@id([organizationId, featureId])
  @@index([organizationId])
  @@index([featureId])
}

// 13. Notifications
model Notification {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String       @default("IN_APP") // IN_APP
  event          String       // TASK_ASSIGNED, TASK_DUE, DEAL_WON, USER_INVITED
  title          String
  message        String
  entityType     String?
  entityId       String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([readAt])
  @@index([createdAt])
  @@index([entityType, entityId])
}

// 14. SaaS Subscription Billing
model SubscriptionPlan {
  id             String         @id // "FREE", "STARTER", "GROWTH", "AGENCY"
  name           String
  description    String?
  price          Float          @default(0.0)
  maxUsers       Int
  maxContacts    Int
  maxDeals       Int
  
  // Feature Entitlements
  aiAssistant    Boolean        @default(false)
  emailSync      Boolean        @default(false)
  automation     Boolean        @default(false)
  clientPortal   Boolean        @default(false)
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  subscriptions  Subscription[]
}

model Subscription {
  id             String           @id @default(uuid())
  organizationId String           @unique
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId         String
  plan           SubscriptionPlan @relation(fields: [planId], references: [id])
  status         String           @default("ACTIVE") // ACTIVE, CANCELED, etc.
  startDate      DateTime         @default(now())
  endDate        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId])
  @@index([planId])
}

model UsageMetric {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  metricKey      String       // USERS, CONTACTS, DEALS
  value          Int          @default(0)
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, metricKey])
  @@index([organizationId])
}

// 15. Automation Rules Engine
model AutomationRule {
  id             String               @id @default(uuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  triggerEvent   AutomationTrigger
  conditionsJson Json?                // Sprint 8.2 criteria configuration
  isEnabled      Boolean              @default(true)
  version        Int                  @default(1)    // Rule versioning tracker
  failureCount   Int                  @default(0)    // Consecutive failure tracking
  lastFailureAt  DateTime?                           // Observability for auto-disable logic
  templateId     String?                             // Source template tracking
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  // Relations
  actions        AutomationAction[]
  executions     AutomationExecution[]

  @@index([organizationId])
  @@index([triggerEvent])
  @@index([isEnabled])
}

model AutomationAction {
  id                String               @id @default(uuid())
  ruleId            String
  rule              AutomationRule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  actionType        AutomationActionType
  configurationJson Json                 // Stores template bodies and dynamic settings

  @@index([ruleId])
}

model AutomationExecution {
  id                    String                    @id @default(uuid())
  automationExecutionId String                    @unique // Distributed trace ID
  organizationId        String
  organization          Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ruleId                String
  rule                  AutomationRule            @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  triggerEvent          String
  triggerEntityType     String?                   // e.g. "contact", "deal", "task"
  triggerEntityId       String?
  status                AutomationExecutionStatus // Type-safe execution status enum
  startedAt             DateTime
  completedAt           DateTime?
  errorMessage          String?
  metadata              Json?                     // Stores executed rule version, performance metrics, etc.
  createdAt             DateTime                  @default(now())

  @@index([organizationId])
  @@index([ruleId])
  @@index([status])
}

enum AutomationTrigger {
  CONTACT_CREATED
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  DEAL_WON
  TASK_COMPLETED
  USER_INVITED
}

enum AutomationActionType {
  CREATE_TASK
  SEND_NOTIFICATION
  SEND_EMAIL
}

enum AutomationExecutionStatus {
  STARTED
  SUCCESS
  FAILED
  SKIPPED
}

